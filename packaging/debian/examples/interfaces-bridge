# Bridged uplink for the emulated Ethernet controller, for
# /etc/network/interfaces or a file under /etc/network/interfaces.d.
#
# This moves the host's address from the uplink onto the bridge. Apply it
# with console access, not over ssh: a mistake here leaves a headless board
# unreachable. The package does not install it for that reason.
#
# Replace the MAC with the uplink's own. Pinning it keeps the DHCP lease -
# a bridge otherwise takes the lowest port address and the machine changes
# address when a port is added.
#
# With this in place, set BRIDGE=br0 in /etc/qbone/network.conf so the
# emulator's veth joins the bridge; the pre-up lines below then only need to
# cover the bridge and the uplink.

iface eth0 inet manual

auto br0
iface br0 inet dhcp
	hwaddress ether 90:59:af:55:a3:67
	pre-up ip link add name br0 type bridge
	pre-up ip link set br0 address 90:59:af:55:a3:67
	# no learning delay, so the emulator sees the network as soon as it starts
	pre-up ip link set br0 type bridge forward_delay 0 || true
	pre-up ip link set eth0 up
	pre-up ip link set eth0 master br0
	post-down ip link set eth0 nomaster || true
	post-down ip link del br0 || true
