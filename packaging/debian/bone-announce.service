[Unit]
Description=Announce the address the board can be reached at
Documentation=file:/usr/share/bone/README.Debian
# the bridge carries the address, so wait for the network and for the veth pair
After=network-online.target bone-network.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/sbin/bone-announce
# on the console as well as in the journal: on a first boot the console is the
# only place anyone is looking
StandardOutput=journal+console

[Install]
WantedBy=multi-user.target
