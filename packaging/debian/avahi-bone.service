<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<!--
  Advertise the emulator's web interface over DNS-SD, so the board announces
  itself to a service browser instead of having to be found by address. Safari's
  Bonjour list, avahi-browse and the file manager's network view all pick it up.

  A template: bone-setup installs the copy under /etc/avahi/services with the
  board's own identifier substituted in. Boards ship with one hostname, so
  several on a network collide and mDNS renames the later ones by boot order;
  the identifier comes from the uplink MAC and stays with the board whatever its
  name becomes. %h is the board's current name, so a renamed board leads with
  the name its owner gave it.

  Read by avahi-daemon, which watches this directory: no restart is needed after
  a change, and the file is inert on a system with no avahi installed.
-->
<service-group>
  <name replace-wildcards="yes">%h (BOARDID)</name>
  <service>
    <type>_http._tcp</type>
    <port>80</port>
  </service>
</service-group>
