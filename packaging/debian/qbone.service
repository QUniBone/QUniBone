[Unit]
Description=PDP-11 Qbus device emulator
Documentation=file:/usr/share/bone/README.Debian
After=network.target bone-network.service bone-setup.service bbbio-set-sysconf.service
Requires=bone-network.service
# bbbio-set-sysconf may reboot on a first boot to apply base-image settings; if
# it does, the emulator must not have started, because a SIGTERM caught in its
# PRU startup is uninterruptible and would hang the reboot. Ordering after it
# means the emulator starts only on a boot where it has nothing left to do.

[Service]
Type=simple
Environment=QUNIBONE_DIR=/var/lib/bone
WorkingDirectory=/var/lib/bone
# The PRU cores are driven through remoteproc, and pru_rproc binds them a
# moment after the modules load: on a cold boot the emulator would otherwise
# reach for PRUs that are not there yet and exit. Wait for both cores to carry
# a remoteproc device before starting.
ExecStartPre=/bin/sh -c 'i=0; while [ $i -lt 100 ]; do [ -e /sys/bus/platform/devices/4a334000.pru/remoteproc ] && [ -e /sys/bus/platform/devices/4a338000.pru/remoteproc ] && exit 0; i=$((i+1)); sleep 0.2; done; echo "PRU cores did not appear under remoteproc" >&2; exit 1'

# The machine the board comes up as is the configuration designated the default
# through the web interface, applied at startup. Configurations are saved from
# the web interface and live in /var/lib/bone/configs. "--config <name>"
# overrides the default for bring-up and testing.
ExecStart=/usr/bin/qbone --port 80 --webroot /usr/share/bone/frontend \
    --addresswidth 22
# The bus engine runs at realtime priority and the PRU driver wants physical
# memory, so this stays privileged.
LimitRTPRIO=99
LimitMEMLOCK=infinity
Restart=no
# Answering SIGTERM shuts the device set down in order, but a stop must never
# be able to hang a reboot: if the process has not exited in time - e.g. a
# SIGTERM caught mid-startup - systemd sends SIGKILL and the reboot proceeds.
TimeoutStopSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
