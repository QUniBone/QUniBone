#!/bin/sh
# One-shot setup for a freshly installed qbone package.
#
# Checks the hardware the emulator needs, puts the emulated Ethernet controller
# on the network, and starts the services. Safe to run again: everything it
# does is checked before it is done.
#
# Two of the changes take effect only after a reboot, so this runs in two
# passes. The first applies boot settings, swaps eth0 onto the legacy Ethernet
# driver, and writes the bridge configuration; it then asks for a reboot. The
# second, after the reboot, finds everything in place and starts the services.
#
# Why the driver swap: the DELQA emulation needs a promiscuous interface
# carrying the guest's several MAC addresses, bridged to both the LAN and this
# board. That needs a plain, bridgeable NIC. The stock 6.x device tree binds
# the switchdev cpsw driver, whose eth0 is a hardware switch port the kernel
# refuses to add to a software bridge, so eth0 is moved to the legacy ti,cpsw
# driver by a device tree built here. See /usr/share/doc/qbone/README.Debian.
#
# usage:
#   qbone-setup                 set up, including the network
#   qbone-setup --no-network    set up without touching the network

set -e

UENV=/boot/uEnv.txt
CONF=/etc/qbone/network.conf
DTS=/usr/share/qbone/am335x-boneblack-qbone.dts
NETSRC=/usr/share/qbone/network
NETDIR=/etc/systemd/network
# the file U-Boot loads on this image (uboot_base_dtb_univ), not the base or a
# board-revision variant
BASE_DTB=am335x-boneblack-uboot.dtb

WANT_NET=yes
AUTO=no
while [ $# -gt 0 ]; do
    case "$1" in
        --no-network|--no-bridge) WANT_NET=no ;;
        # unattended: reboot between passes instead of asking, and hand the
        # hardware check and emulator startup to the enabled units. Used by
        # qbone-setup.service so a distribution image configures itself with no
        # login. It stops running once /var/lib/qbone/.setup-done exists.
        --auto) AUTO=yes ;;
        *) echo "usage: $0 [--no-network] [--auto]" >&2; exit 2 ;;
    esac
    shift
done

say() { echo "qbone-setup: $*"; }
die() { echo "qbone-setup: $*" >&2; exit 1; }

[ "$(id -u)" = 0 ] || die "must run as root"

NEED_REBOOT=

# ------------------------------------------------------------ boot settings

# Up to 4.19 the cape overlay came from the cape's own EEPROM through
# bone_capemgr, and nothing here had to be configured. After that the overlay
# is applied by U-Boot, and which overlays it applies is named in
# /boot/uEnv.txt - so on a modern kernel that file decides whether the cape
# works at all.

capemgr() { ls -d /sys/devices/platform/bone_capemgr* >/dev/null 2>&1; }

# set_uenv KEY VALUE: make "KEY=VALUE" the active setting, whether the line is
# absent, commented out, or set to something else.
set_uenv() {
    if grep -q "^$1=$2\$" $UENV; then return 1; fi
    if grep -qE "^#?$1=" $UENV; then
        sed -i "s|^#\?$1=.*|$1=$2|" $UENV
    else
        echo "$1=$2" >> $UENV
    fi
    return 0
}

# comment_uenv KEY: leave the line in place but stop it taking effect
comment_uenv() {
    grep -q "^$1=" $UENV || return 1
    sed -i "s|^$1=|#$1=|" $UENV
    return 0
}

configure_boot() {
    changed=
    comment_uenv uboot_overlay_pru && changed="$changed uboot_overlay_pru"
    for k in emmc video audio; do
        set_uenv "disable_uboot_overlay_$k" 1 && changed="$changed disable_$k"
    done
    set_uenv enable_uboot_overlays 1 && changed="$changed enable_overlays"
    if grep -q "^uboot_overlay_addr4=" $UENV &&
       ! grep -q "^uboot_overlay_addr4=QBone.dtbo\$" $UENV; then
        say "  uboot_overlay_addr4 is already set to something else; leaving it"
        say "  alone. Put QBone.dtbo in a free uboot_overlay_addrN slot by hand."
    else
        set_uenv uboot_overlay_addr4 QBone.dtbo && changed="$changed addr4"
    fi
    [ -n "$changed" ] || return 1
    say "  changed in $UENV:$changed"
    return 0
}

if ! capemgr && [ -f $UENV ]; then
    say "checking the boot settings"
    cp -n $UENV $UENV.qbone-orig 2>/dev/null || true
    if configure_boot; then
        say "  boot settings applied; the original is kept at $UENV.qbone-orig"
        NEED_REBOOT=yes
    else
        say "  boot settings already correct"
    fi
fi

# ------------------------------------------------ eth0 as a plain NIC (DTB)

# The DTB is built from the device tree sources the base image ships in
# /opt/source, so it follows whatever kernel is installed rather than being
# pinned to one. It is installed under the name U-Boot loads.
dt_src_dir() {
    # /opt/source/dtb-<major>.<minor>.x for the running kernel
    kv=$(uname -r | cut -d. -f1-2)
    for d in /opt/source/dtb-${kv}.x /opt/source/dtb-${kv}; do
        [ -d "$d/src/arm/ti/omap" ] && { echo "$d"; return 0; }
    done
    return 1
}

# eth0 already plain (legacy driver) if it carries no switchdev id
eth0_is_plain() {
    [ -e /sys/class/net/eth0 ] || return 1
    ! ip -d link show eth0 2>/dev/null | grep -q "switchid"
}

# ETH_DTB_STATE, set by configure_ethernet_dtb: applied | present | plain |
# unavailable
configure_ethernet_dtb() {
    ETH_DTB_STATE=unavailable
    dtbdir=/boot/dtbs/$(uname -r)
    target=$dtbdir/$BASE_DTB

    # if it is already the legacy DTB, nothing to do
    if [ -e "$target" ] &&
       [ "$(fdtget "$target" \
            /ocp/interconnect@4a000000/segment@0/target-module@100000/ethernet@0 \
            status 2>/dev/null)" = okay ]; then
        ETH_DTB_STATE=present
        return 0
    fi

    src=$(dt_src_dir) || {
        say "  no device tree sources under /opt/source for kernel $(uname -r);"
        say "  cannot build the Ethernet device tree. The emulated controller"
        say "  will not reach the network. Install the dtb source package, or"
        say "  build $BASE_DTB by hand from $DTS."
        return 1
    }
    for t in dtc cpp make; do
        command -v $t >/dev/null 2>&1 || {
            say "  $t is missing; cannot build the Ethernet device tree."
            return 1
        }
    done
    [ -r "$DTS" ] || { say "  $DTS is missing"; return 1; }

    say "building the legacy-Ethernet device tree for $(uname -r)"
    cp "$DTS" "$src/src/arm/ti/omap/"
    dtb=$src/src/arm/ti/omap/am335x-boneblack-qbone.dtb
    ( cd "$src" && make ARCH=arm CPP=cpp DTC=dtc \
        src/arm/ti/omap/am335x-boneblack-qbone.dtb ) >/dev/null 2>&1 || {
        say "  the device tree build failed"
        return 1
    }
    [ -e "$dtb" ] || { say "  the device tree build produced no output"; return 1; }
    [ -e "$target.stock" ] || cp "$target" "$target.stock"
    cp "$dtb" "$target"
    say "  installed $BASE_DTB (legacy ti,cpsw); the stock one is $BASE_DTB.stock"
    ETH_DTB_STATE=applied
    return 0
}

if ! capemgr; then
    if configure_ethernet_dtb; then
        [ "$ETH_DTB_STATE" = applied ] && NEED_REBOOT=yes
    else
        # cannot make eth0 bridgeable; do not touch the network below, or the
        # networkd bridge would fail to enslave the switch port and take the
        # board off the network
        WANT_NET=no
    fi
else
    ETH_DTB_STATE=plain
fi

# ------------------------------------------------------------- the bridge

# uplink MAC, so the bridge keeps the same DHCP identity
uplink() { ip route show default 2>/dev/null | awk '/^default/ {print $5; exit}'; }

install_bridge() {
    changed=
    # the uplink whose driver we manage is eth0; a bridge over anything else is
    # the operator's own setup
    mac=$(cat /sys/class/net/eth0/address 2>/dev/null)
    [ -n "$mac" ] || { say "  no eth0 to bridge"; return 1; }

    # br0.netdev with the uplink MAC pinned in
    tmp=$(mktemp)
    sed "s|^# MACAddress set by qbone-setup.*|MACAddress=$mac|" \
        "$NETSRC/br0.netdev" > "$tmp"
    # usb0.network addresses the USB gadget, the way in when the board's
    # address on the bridge is not known; it is inert without the gadget
    for f in br0.network eth0.network veth-br.network veth-pdp.network usb0.network; do
        cmp -s "$NETSRC/$f" "$NETDIR/$f" || { cp "$NETSRC/$f" "$NETDIR/$f"; changed=yes; }
    done
    cmp -s "$tmp" "$NETDIR/br0.netdev" || { cp "$tmp" "$NETDIR/br0.netdev"; changed=yes; }
    rm -f "$tmp"
    # networkd reads its configuration as the systemd-network user; the mktemp
    # source is private, so the copied file inherits 0600 and networkd cannot
    # read it. Make it world-readable like the files copied from the package.
    chmod 644 "$NETDIR/br0.netdev"

    # remove an old ifupdown bridge stanza that would fight networkd
    if [ -e /etc/network/interfaces.d/qbone ]; then
        mv /etc/network/interfaces.d/qbone /etc/network/interfaces.d/qbone.disabled
        say "  moved the old ifupdown bridge stanza aside"
        changed=yes
    fi

    [ -n "$changed" ] || return 1
    return 0
}

if [ $WANT_NET = yes ]; then
    say "configuring the bridge (systemd-networkd)"
    if install_bridge; then
        say "  br0 = eth0 + veth-br; the host address moves onto br0 on reboot"
        NEED_REBOOT=yes
    else
        say "  bridge already configured"
    fi
    # qbone-network only creates the veth pair; networkd enslaves it
    if grep -q "^BRIDGE=." $CONF 2>/dev/null; then
        sed -i "s|^BRIDGE=.*|BRIDGE=|" $CONF
    fi
else
    say "leaving the network alone"
    say "  the emulated machine will not reach the network until the bridge is set up"
fi

# ------------------------------------------------------- service discovery

# The DNS-SD advertisement, with this board's identifier substituted into the
# template. The identifier is the last three octets of the uplink MAC, the same
# bytes the emulated Ethernet controller takes its station address from, so a
# board keeps one identity across the LAN and the emulated machine. Without an
# eth0 the name carries no identifier and mDNS alone separates the boards.
install_avahi_service() {
    src=/usr/share/qbone/avahi-qbone.service
    dst=/etc/avahi/services/qbone.service
    [ -r "$src" ] || return 1
    # only where an avahi is installed to read it
    [ -d /etc/avahi/services ] || return 1

    mac=$(cat /sys/class/net/eth0/address 2>/dev/null || true)
    id=$(echo "$mac" | tr -d ':' | tr 'A-Z' 'a-z' | cut -c7-12)
    tmp=$(mktemp)
    if [ -n "$id" ]; then
        sed "s|QBone ID|QBone $id|" "$src" > "$tmp"
    else
        # drop the parenthesised identifier rather than advertise an empty one
        sed "s| (QBone ID)||" "$src" > "$tmp"
    fi
    if cmp -s "$tmp" "$dst"; then
        rm -f "$tmp"
        return 1
    fi
    cp "$tmp" "$dst"
    chmod 644 "$dst"
    rm -f "$tmp"
    return 0
}

if install_avahi_service; then
    say "advertising the web interface over DNS-SD"
fi

# --------------------------------------------------- reboot between passes

if [ -n "$NEED_REBOOT" ]; then
    if [ "$AUTO" = yes ]; then
        # Generate the ssh host keys now if the image shipped none. After this
        # reboot systemd no longer counts the boot as the first, so
        # sshd-keygen.service (ConditionFirstBoot=yes) would not run and ssh
        # would fail for want of keys. ssh-keygen -A only makes missing ones.
        ls /etc/ssh/ssh_host_*_key >/dev/null 2>&1 || ssh-keygen -A >/dev/null 2>&1 || true
        say "settings applied; rebooting to bring up the bridge"
        systemctl reboot
        exit 0
    fi
    say "settings applied. Reboot, then run 'sudo qbone-setup' again to start"
    say "the services:  sudo reboot"
    exit 0
fi

# Past the reboot point the network is fully configured. Unattended, that is
# all this does: the enabled qbone-network and qbone units check the hardware
# and start the emulator. Record that setup is done so the service stops here.
if [ "$AUTO" = yes ]; then
    mkdir -p /var/lib/qbone
    : > /var/lib/qbone/.setup-done
    say "network configured; the qbone service starts the emulator"
    exit 0
fi

# ---------------------------------------------------------------- hardware

say "checking the hardware"

if capemgr; then
    [ -e /dev/uio0 ] || die "no /dev/uio0: the PRU UIO driver is not loaded, and
  the bus engine cannot run without it. Check that uio_pruss is available."
    cat /sys/devices/platform/bone_capemgr*/slots 2>/dev/null | grep -qi unibone ||
        die "the cape overlay is not loaded. /lib/firmware/UniBone-00B0.dtbo
  ships with this package and capemgr loads it from the cape's own EEPROM, so
  this usually means the cape is not seated or not powered."
    say "  PRU and cape present"
else
    ls -d /proc/device-tree/reserved-memory/qbone-ddr* >/dev/null 2>&1 ||
        die "the cape overlay is not applied: no qbone-ddr reserved-memory
  region. /lib/firmware/QBone.dtbo ships with this package and U-Boot applies
  it when uEnv.txt names it. Reboot if the boot settings were just changed."
    grep -q "\.pru\$" /sys/class/remoteproc/*/name 2>/dev/null ||
        die "no PRU remoteproc devices. The shipped PRU overlay overwrites the
  PRU-ICSS compatible with one no driver has bound since 6.10; uboot_overlay_pru
  in $UENV has to stay commented out."
    grep -qi qbone /sys/class/uio/*/name 2>/dev/null ||
        die "no PRU event device. uio_pdrv_genirq takes the compatible it binds
  to from a module parameter; /etc/modprobe.d/qbone.conf ships with this package
  and sets it. Try 'modprobe -r uio_pdrv_genirq; modprobe uio_pdrv_genirq'."
    say "  PRU, cape overlay and event device present"

    # the Ethernet driver swap has to have taken effect for the bridge to work
    if [ $WANT_NET = yes ] && ! eth0_is_plain; then
        die "eth0 is still a switch port: the legacy-Ethernet device tree is not
  in effect. If the boot settings or the device tree were just installed, reboot
  and run qbone-setup again."
    fi
fi

# --------------------------------------------------------- emulator startup

say "starting services"
systemctl enable qbone-network qbone >/dev/null 2>&1 || true
systemctl restart qbone-network
systemctl restart qbone

sleep 2
if systemctl is-active --quiet qbone; then
    IFACE=br0; [ -e /sys/class/net/br0 ] || IFACE=$(uplink)
    ADDR=$(ip -4 -o addr show "$IFACE" 2>/dev/null | awk '{print $4}' | cut -d/ -f1)
    say "running: http://${ADDR:-this board}/"
else
    die "the emulator did not start. journalctl -u qbone"
fi
