# compile-bbb.env
#
# Environment variables to compile UniBone on BBB itself
# Used in Makefiles

# installation root; presettable (e.g. in qunibone-platform.env)
# for installations outside $HOME, such as a git clone in ~/QUniBone
export QUNIBONE_DIR=${QUNIBONE_DIR:-$HOME}
export BBB_CC=gcc
export PRU_CGT=/usr/share/ti/cgt-pru/
ln -s /usr/bin/ /usr/share/ti/cgt-pru/bin

