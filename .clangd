# clangd configuration for editing QBone C++ in an IDE.
#
# The build drives the real compiler through the makefiles (and the Docker
# crossbuild); a bare clangd has none of their -I paths or -D defines, so it
# reports spurious "file not found" errors for civetweb.h, logger.hpp and the
# like, which then cascade into undeclared-identifier noise. These flags give
# clangd the same view the QBUS build has, so those false diagnostics disappear.
#
# Notes:
# - Paths are relative to this file (the repo root); clangd resolves them from
#   the workspace root.
# - -D__linux__ steers the platform #ifdefs (e.g. rs232.hpp) to the POSIX branch
#   the Linux/ARM board actually compiles, rather than the Windows fallback a
#   macOS or other host would otherwise take.
# - The host toolchain's headers are used for the standard library, which is
#   enough to parse the project's own sources.
CompileFlags:
  Add:
    - -std=c++11
    - -D__linux__
    - -DARM
    - -DQBUS
    - -DBLINKENLIGHT_CLIENT
    - -DDBG
    - -DWEBUI
    - -DUSE_WEBSOCKET
    - -DNO_SSL
    - -DNO_CGI
    - -I90_common/src
    - -I10.01_base/2_src/shared
    - -I10.01_base/2_src/arm
    - -I10.02_devices/2_src
    - -I10.02_devices/2_src/blinkenbone
    - -I10.04_device_exerciser/2_src
    - -I10.03_app_demo/2_src
    - -I10.05_web/2_src
    - -I91_3rd_party/civetweb
    - -I91_3rd_party/picojson
